<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>ByBlogSite</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet">

    <style>

        body {

            margin: 0;
            padding: 0;
            background-color: #171A21;
            font-family: Arial, Helvetica, sans-serif;
            overflow-x: hidden;
            color: white;

        }

        .navbar {

            z-index: 1000;
            background-color: #171A21 !important;
            padding-left: 20px;
            padding-right: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.08);

        }

        .navbar-brand {

            font-size: 2rem;
            font-weight: bold;

        }

        .nav-link {

            font-size: 1.1rem;
            margin-left: 15px;

        }

        .hero-section {

            position: relative;
            width: 100%;
            height: calc(100vh - 56px);
            overflow: hidden;

        }

        .hero-image {

            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;

        }

        .overlay {

            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.45);
            z-index: 1;

        }

        .hero-content {

            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 2;
            text-align: center;
            color: white;
            width: 90%;
            max-width: 900px;

        }

        .hero-content h1 {

            font-size: 5rem;
            font-weight: bold;
            text-shadow: 2px 2px 15px rgba(0, 0, 0, 0.7);

        }

        .hero-content p {

            font-size: 1.5rem;
            margin-top: 20px;
            margin-bottom: 30px;
            text-shadow: 1px 1px 10px rgba(0, 0, 0, 0.7);

        }

        .hero-content .btn {

            padding: 15px 40px;
            font-size: 1.2rem;
            border-radius: 10px;

        }

        .btn-primary {

            background-color: #1A74E8;
            border: none;

        }

        @media (max-width: 992px) {

            .hero-content h1 {

                font-size: 3.5rem;

            }

            .hero-content p {

                font-size: 1.2rem;

            }

        }

        @media (max-width: 768px) {

            .hero-content h1 {

                font-size: 2.5rem;

            }

            .hero-content p {

                font-size: 1rem;

            }

            .hero-content .btn {

                width: 100%;
                max-width: 300px;

            }

            .navbar-brand {

                font-size: 1.6rem;

            }

        }

        @media (max-width: 576px) {

            .navbar-brand {

                font-size: 1.3rem;

            }

            .hero-content h1 {

                font-size: 2rem;

            }

            .hero-content p {

                font-size: 0.95rem;

            }

            .btn {

                width: 100%;
                margin-top: 10px;

            }

        }

    </style>

</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">

        <div class="container-fluid">

            <a class="navbar-brand" href="/home">
                Michael Clarks Blog Site
            </a>

            <button
                class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarNav">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <ul class="navbar-nav ms-auto">

                    <li class="nav-item">

                        <a class="nav-link active" href="/home">
                            Home
                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link" href="/blog-post">
                            Blog Posts
                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link" href="#">
                            About
                        </a>

                    </li>

                </ul>

            </div>

        </div>

    </nav>

    <section class="hero-section">

        <div class="overlay"></div>

        <img
            src="/images/2.png"
            alt="Hero Image"
            class="hero-image">

        <div class="hero-content">

            <h1>
                Portfolio Project 5
            </h1>

            <p>
                Development Blog • Express • MongoDB • EJS • Bootstrap
            </p>

            <a href="/blog-post" class="btn btn-primary btn-lg">
                Enter Blog
            </a>

        </div>

    </section>

    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>

</body>

</html>